{
  "name": "@float-code/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./protocol": {
      "types": "./src/protocol/types.ts",
      "default": "./dist/protocol/types.js"
    },
    "./protocol/entry-guard": {
      "types": "./src/protocol/entry-guard.ts",
      "default": "./dist/protocol/entry-guard.js"
    },
    "./crypto/sign": {
      "types": "./src/crypto/sign.ts",
      "default": "./dist/crypto/sign.js"
    },
    "./crypto/ed25519-setup": {
      "types": "./src/crypto/ed25519-setup.ts",
      "default": "./dist/crypto/ed25519-setup.js"
    },
    "./crypto/pairing-code": {
      "types": "./src/crypto/pairing-code.ts",
      "default": "./dist/crypto/pairing-code.js"
    },
    "./crypto/uuid": {
      "types": "./src/crypto/uuid.ts",
      "default": "./dist/crypto/uuid.js"
    },
    "./crypto/request-sign": {
      "types": "./src/crypto/request-sign.ts",
      "default": "./dist/crypto/request-sign.js"
    },
    "./crypto/signed-fetch": {
      "types": "./src/crypto/signed-fetch.ts",
      "default": "./dist/crypto/signed-fetch.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm run build && pnpm run lint && pnpm run format:check"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.1",
    "@noble/hashes": "^2.0.1",
    "@palon7/cc-client": "^0.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  }
}
