{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "lib": ["ES2023", "DOM", "DOM.Iterable"]
  },
  "include": ["src"],
  "exclude": ["scripts"]
}
